{
    "manifest_version": 3,
    "name": "LinguaSub AI",
    "version": "1.1.0",
    "description": "AI-powered subtitle generation and translation for any video.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "icons": {
        "128": "icons/icon128.png"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [
                "content/overlay.css"
            ],
            "all_frames": true
        }
    ]
}